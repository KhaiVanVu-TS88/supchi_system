# ===== ENVIRONMENT VARIABLES =====
# Copy thành .env và điền giá trị khi deploy lên VPS

# Port cho các service
BACKEND_PORT=8000
FRONTEND_PORT=3000

# URL public khi deploy VPS (thay bằng domain thật)
# NEXT_PUBLIC_BACKEND_URL=https://api.yourdomain.com
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
