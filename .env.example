# ===== ENVIRONMENT VARIABLES v3 =====
# cp .env.example .env

# ── Bắt buộc đổi khi deploy VPS ──
SECRET_KEY=supchi4-change-to-long-random-string
DB_PASSWORD=supchi4pass

# ── Frontend ──
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# ── Tuỳ chỉnh ──
# Video dài hơn N phút → API trả hộp thoại xác nhận trước khi tạo job (mặc định 20)
# VIDEO_DURATION_WARNING_MINUTES=20

# yt-dlp / YouTube: nếu log báo "Sign in to confirm you're not a bot", export cookie Netscape
# (vd. extension "Get cookies.txt LOCALLY" trên youtube.com), đặt file vào secrets/youtube_cookies.txt,
# bỏ comment volume trong docker-compose cho backend + worker-video, rồi:
# YTDLP_COOKIES_FILE=/secrets/youtube_cookies.txt
# (Biến thay thế: YOUTUBE_COOKIES_FILE — không commit file cookie lên git.)
# Vẫn lỗi bot dù có cookie: thử bỏ proxy chỉ cho yt-dlp (Compose vẫn có HTTP_PROXY cho service khác)
# YTDLP_DISABLE_PROXY=1
# PO token (YouTube 2025+): https://github.com/yt-dlp/yt-dlp/wiki/Extractors#po-token-guide
# YTDLP_YOUTUBE_PO_TOKEN=
# YTDLP_YOUTUBE_PO_CLIENT=mweb
# YTDLP_YOUTUBE_PLAYER_CLIENT=mweb,web
# SSL EOF / proxy cắt giữa chừng: YTDLP_RETRIES, YTDLP_FRAGMENT_RETRIES, YTDLP_SOCKET_TIMEOUT, YTDLP_CONCURRENT_FRAGMENTS=1

ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
