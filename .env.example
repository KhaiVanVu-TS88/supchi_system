# ===== ENVIRONMENT VARIABLES v3 =====
# cp .env.example .env

# ── Bắt buộc đổi khi deploy VPS ──
SECRET_KEY=supchi4-change-to-long-random-string
DB_PASSWORD=supchi4pass

# ── Frontend ──
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# ── LLM (optional) ──
# Nếu có key → bật LLM post-processing tự động
# Nếu không có → pipeline vẫn chạy bình thường
# ANTHROPIC_API_KEY=sk-ant-...

# ── Tuỳ chỉnh ──
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
