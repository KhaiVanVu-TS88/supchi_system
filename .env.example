# ===== ENVIRONMENT VARIABLES =====
# Copy thành .env trước khi chạy:
#   cp .env.example .env

# ── Bắt buộc đổi khi deploy lên VPS ──
SECRET_KEY=supchi4-change-this-to-a-long-random-string-in-production
DB_PASSWORD=supchi4pass

# ── Frontend (URL backend public cho browser) ──
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# ── Tuỳ chỉnh ──
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Khi deploy VPS, đổi thành domain thật ──
# NEXT_PUBLIC_BACKEND_URL=https://api.yourdomain.com
# FRONTEND_URL=https://yourdomain.com
